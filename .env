# ============================================================
#  AWS Route53 Auto-Update — 环境变量配置
# ============================================================

# ---------- 飞书机器人 ----------
FEISHU_WEBHOOK_TOKEN=xxx

# ---------- 目标名称（用于飞书通知标题）----------
TARGET_NAME=abc/dfg

# ---------- AWS 凭证 ----------
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_DEFAULT_REGION=ap-northeast-1

# ---------- Route53 配置 ----------
ZONE_ID=xxx

# ⚠️ 多个域名用空格分隔（Docker env_file 不支持 bash 数组语法）
RECORD_NAMES=xxx.xxx.com xxx.xxx.com

# ---------- IP 文件路径（容器内路径）----------
IP_CACHE_FILE=/host-tmp/new_public_ip.txt

# ---------- Cron 调度（Asia/Shanghai 时区）----------
CHECK_CRON_SCHEDULE=*/1 * * * *

# ---------- 时区 ----------
TZ=Asia/Shanghai